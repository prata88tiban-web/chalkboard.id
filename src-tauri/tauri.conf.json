{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chalkboard",
  "version": "1.0.0",
  "identifier": "com.kugie.chalkboard",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build:desktop && node scripts/prepare-tauri-server.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "Chalkboard - Billiard Hall Management",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://localhost:3000; connect-src 'self' http://localhost:* https://localhost:*; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "app", "dmg", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Billiard Hall Management System",
    "longDescription": "Professional billiard hall management system with table tracking, F&B orders, and payment processing",
    "publisher": "Kugie",
    "copyright": "Copyright © 2024-2026 Kugie. All rights reserved.",
    "category": "Business",
    "fileAssociations": [],
    "resources": {
      "../.next/standalone": "standalone"
    }
  }
}
